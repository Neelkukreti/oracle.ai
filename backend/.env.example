# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — enables live RSI/MACD/EMA indicators
# Set up your own TAAPI proxy or use TAAPI directly
TAAPI_PROXY_URL=https://your-proxy.example.com/api/taapi-proxy
TAAPI_PROXY_KEY=your_taapi_proxy_key_here

# Server config
PORT=8080
LOG_LEVEL=info
